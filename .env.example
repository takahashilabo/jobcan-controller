# ── テスト用 ──────────────────────────────────────────────────────────────────
# true にするとブラウザを開かず動作確認できる
MOCK=false

# ── Jobcan ───────────────────────────────────────────────────────────────────
JOBCAN_URL=https://ssl.jobcan.jp/employee
# セッション切れ時の SAML ログイン URL（Jobcan 管理者から入手）
JOBCAN_SSO_URL=https://id.jobcan.jp/users/saml/select_idp?client_code=XXXXX&app_key=atd

# ── 大学 SSO ─────────────────────────────────────────────────────────────────
# リダイレクト先 URL に含まれる文字列（例: sso.example-univ.ac.jp）
SSO_URL_PATTERN=

# 大学アカウントのログイン情報
SSO_USERNAME=
SSO_PASSWORD=

# SSO ログインフォームのセレクタ（デフォルトのままで動かない場合に変更）
SSO_USERNAME_SELECTOR=input[name='username']
SSO_PASSWORD_SELECTOR=input[name='password']
SSO_SUBMIT_SELECTOR=button[type='submit']
